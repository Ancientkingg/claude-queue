{
  "name": "claude-queue",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "db:push": "pnpm --filter @claude-queue/api exec prisma db push",
    "db:studio": "pnpm --filter @claude-queue/api exec prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
